{
  "builds": [
    {
      "src": "rock-paper-scissors-game/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "weather/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "hnm-react-prc/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "zustand-counter/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/rock-paper-scissors-game",
      "dest": "rock-paper-scissors-game/dist/index.html"
    },
    {
      "src": "/rock-paper-scissors-game/(.*)",
      "dest": "rock-paper-scissors-game/dist/$1"
    },
    {
      "src": "/weather",
      "dest": "weather/dist/index.html"
    },
    {
      "src": "/weather/(.*)",
      "dest": "weather/dist/$1"
    },
    {
      "src": "/hnm-react-prc",
      "dest": "hnm-react-prc/dist/index.html"
    },
    {
      "src": "/hnm-react-prc/(.*)",
      "dest": "hnm-react-prc/dist/$1"
    },
    {
      "src": "/zustand-counter",
      "dest": "zustand-counter/dist/index.html"
    },
    {
      "src": "/zustand-counter/(.*)",
      "dest": "zustand-counter/dist/$1"
    }
  ]
}